{
  "name": "@jimmyyen/opencode-registry-plugin",
  "version": "0.1.0",
  "description": "Attention-management plugin for OpenCode — soft-steers the model toward the right MCP tools via system-prompt hints and tool-description down-ranking, reducing tool-use hallucination from an overcrowded tool list.",
  "type": "module",
  "main": "plugins/registry.ts",
  "files": [
    "plugins/",
    "src/",
    "profiles/",
    "examples/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/src/**/*.test.js"
  },
  "keywords": [
    "opencode",
    "plugin",
    "mcp",
    "registry",
    "context-aware",
    "tool-scoping"
  ],
  "license": "MIT",
  "publishConfig": {
    "tag": "latest",
    "access": "public"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "@opencode-ai/plugin": "^1.17.8",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "overrides": {
    "@opencode-ai/plugin": {
      "zod": "4.4.3"
    },
    "@opencode-ai/sdk": {
      "zod": "4.4.3"
    }
  }
}
